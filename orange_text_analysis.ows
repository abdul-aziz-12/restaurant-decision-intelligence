		<properties node_id="19" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\x8f\x00\x00\x00d\x00\x00\x04\xb1\x00\x00\x02\xda\x00\x00\x01\x90\x00\x00\x00\x82\x00\x00\x04\xb0\x00\x00\x02\xd9\x00\x00\x00\x00\x00\x00\x00\x00\x05\x00\x00\x00\x01\x90\x00\x00\x00\x82\x00\x00\x04\xb0\x00\x00\x02\xd9', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'import matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.widgets import Slider, Button\nimport numpy as np\nimport textwrap\n\n# ── STEP 1: Fetch all restaurants from Orange in_data ─────────\ndata_dict = {}\nfor row in in_data:\n    try:\n        name = str(row[\'restaurant_name\'])\n    except:\n        try:\n            name = str(row.metas[0])\n        except:\n            name = \'Unknown\'\n\n    try:\n        compound = float(row[\'compound\'])\n    except:\n        compound = 0.0\n\n    if name not in data_dict:\n        data_dict[name] = {\'pos\': 0, \'neg\': 0, \'neu\': 0, \'total\': 0}\n    data_dict[name][\'total\'] += 1\n    if compound &gt; 0.05:\n        data_dict[name][\'pos\'] += 1\n    elif compound &lt; -0.05:\n        data_dict[name][\'neg\'] += 1\n    else:\n        data_dict[name][\'neu\'] += 1\n\n# Remove restaurants with less than 5 reviews\ndata_dict = {k: v for k, v in data_dict.items() if v[\'total\'] &gt;= 5}\nALL_NAMES  = list(data_dict.keys())\nMAX_N      = len(ALL_NAMES)\n\n# Build full arrays\nnames_arr  = np.array(ALL_NAMES)\npos_arr    = np.array([data_dict[n][\'pos\']   for n in ALL_NAMES])\nneg_arr    = np.array([data_dict[n][\'neg\']   for n in ALL_NAMES])\nneu_arr    = np.array([data_dict[n][\'neu\']   for n in ALL_NAMES])\ntotal_arr  = np.array([data_dict[n][\'total\'] for n in ALL_NAMES])\npos_pct    = np.where(total_arr &gt; 0, pos_arr / total_arr * 100, 0)\nneg_pct    = np.where(total_arr &gt; 0, neg_arr / total_arr * 100, 0)\nneu_pct    = np.where(total_arr &gt; 0, neu_arr / total_arr * 100, 0)\n\n\n\n# Helper function\ndef wrap_name(name, max_len=18):\n    if len(name) &lt;= max_len:\n        return name\n    return \'\\n\'.join(textwrap.wrap(name, max_len))\n\n# ── STEP 2: Colors ────────────────────────────────────────────\nBG       = \'#0d0f18\'\nCARD_BG  = \'#13162a\'\nACCENT   = \'#7eb8f7\'\nPOS_COL  = \'#2ecc71\'\nNEG_COL  = \'#e74c3c\'\nNEU_COL  = \'#95a5a6\'\nTEXT_COL = \'#e0e4f0\'\nMUTED    = \'#6b7290\'\nGRID_COL = \'#1e2240\'\nWARM_COL = \'#f39c12\'\n\n# ── STEP 3: State ─────────────────────────────────────────────\nstate = {\n    \'top_n\': min(10, MAX_N),\n    \'from\': 0,\n}\n\n# ── STEP 4: Figure with adjusted layout ─────────────────────\nfig = plt.figure(figsize=(22, 13), facecolor=BG)\nfig.canvas.manager.set_window_title(f\'Restaurant Sentiment Dashboard\')\n\n# Main plot area\ngs = gridspec.GridSpec(2, 3,\n    figure=fig, left=0.08, right=0.98,\n    top=0.92, bottom=0.12,\n    hspace=0.4, wspace=0.35)\n\nax_bar  = fig.add_subplot(gs[0, :2])\nax_dot  = fig.add_subplot(gs[0, 2])\nax_pie  = fig.add_subplot(gs[1, 0])\nax_heat = fig.add_subplot(gs[1, 1])\nax_info = fig.add_subplot(gs[1, 2])\n\nfor ax in [ax_bar, ax_dot, ax_pie, ax_heat, ax_info]:\n    ax.set_facecolor(CARD_BG)\n    for sp in ax.spines.values():\n        sp.set_color(GRID_COL)\n\n# Title\nfig.text(0.5, 0.96, \'🍽️ Restaurant Sentiment Dashboard\',\n         ha=\'center\', fontsize=18, fontweight=\'bold\', color=TEXT_COL)\n\n# ── STEP 5: Controls - Clean and simple ──────────────────────\n# Top N Slider\nax_topn = fig.add_axes([0.08, 0.05, 0.25, 0.04], facecolor=CARD_BG)\nax_topn.set_title(\'Number of Restaurants\', color=TEXT_COL, fontsize=10, pad=6)\nslider_n = Slider(ax_topn, \'\', 5, MAX_N,\n                  valinit=state[\'top_n\'], valstep=1,\n                  color=ACCENT, track_color=GRID_COL)\nslider_n.valtext.set_color(ACCENT)\nslider_n.valtext.set_fontsize(10)\n\n# Start from slider\nax_range = fig.add_axes([0.38, 0.05, 0.25, 0.04], facecolor=CARD_BG)\nax_range.set_title(\'Start from Rank\', color=TEXT_COL, fontsize=10, pad=6)\nslider_from = Slider(ax_range, \'\', 1, max(1, MAX_N - 5),\n                     valinit=1, valstep=1,\n                     color=\'#a569bd\', track_color=GRID_COL)\nslider_from.valtext.set_color(\'#a569bd\')\nslider_from.valtext.set_fontsize(10)\n\n# Quick buttons\nax_b10 = fig.add_axes([0.08, 0.01, 0.07, 0.03])\nax_b20 = fig.add_axes([0.16, 0.01, 0.07, 0.03])\nax_b50 = fig.add_axes([0.24, 0.01, 0.07, 0.03])\n\nbtn10 = Button(ax_b10, \'Show 10\', color=\'#1e2433\', hovercolor=\'#2c3e50\')\nbtn20 = Button(ax_b20, \'Show 20\', color=\'#1e2433\', hovercolor=\'#2c3e50\')\nbtn50 = Button(ax_b50, \'Show All\', color=\'#1e2433\', hovercolor=\'#2c3e50\')\nfor b in [btn10, btn20, btn50]:\n    b.label.set_color(ACCENT)\n    b.label.set_fontsize(8)\n\n# Reset button\nax_rst = fig.add_axes([0.33, 0.01, 0.08, 0.03])\nbtn_rst = Button(ax_rst, \'Reset\', color=\'#1e2433\', hovercolor=\'#2c3e50\')\nbtn_rst.label.set_color(WARM_COL)\nbtn_rst.label.set_fontsize(8)\n\n# ── STEP 6: Helper functions ──────────────────────────────────\ndef get_sorted_indices():\n    order = np.argsort(-pos_pct)\n    start = state[\'from\']\n    end = min(start + state[\'top_n\'], MAX_N)\n    return order[start:end]\n\ndef draw_bar(idx):\n    ax_bar.cla()\n    ax_bar.set_facecolor(CARD_BG)\n    \n    if len(idx) == 0:\n        return\n        \n    y = np.arange(len(idx))\n    h = 0.7\n    \n    left_stack = np.zeros(len(idx))\n    \n    ax_bar.barh(y, pos_arr[idx], h, left=left_stack,\n                color=POS_COL, alpha=0.9, zorder=3, label=\'Positive\')\n    left_stack += pos_arr[idx]\n    \n    ax_bar.barh(y, neu_arr[idx], h, left=left_stack,\n                color=NEU_COL, alpha=0.9, zorder=3, label=\'Neutral\')\n    left_stack += neu_arr[idx]\n    \n    ax_bar.barh(y, neg_arr[idx], h, left=left_stack,\n                color=NEG_COL, alpha=0.9, zorder=3, label=\'Negative\')\n    \n    for i in range(len(idx)):\n        if total_arr[idx[i]] &gt; 5:\n            ax_bar.text(total_arr[idx[i]] + 1, i, f\'{pos_pct[idx[i]]:.0f}%\', \n                       va=\'center\', fontsize=8, color=POS_COL, fontweight=\'bold\')\n\n    n_shown = len(idx)\n    start_r = state[\'from\'] + 1\n    \n    wrapped_names = [wrap_name(name, 25) for name in names_arr[idx]]\n    ax_bar.set_yticks(y)\n    ax_bar.set_yticklabels(wrapped_names, fontsize=8, color=TEXT_COL)\n    ax_bar.set_xlabel(\'Number of Reviews\', color=MUTED, fontsize=10)\n    ax_bar.set_title(f\'Sentiment Distribution (Rank {start_r}–{start_r + n_shown - 1})\',\n                    color=TEXT_COL, fontsize=12, fontweight=\'bold\', pad=10, loc=\'right\')\n    ax_bar.tick_params(colors=MUTED)\n    ax_bar.grid(axis=\'x\', color=GRID_COL, lw=0.5, alpha=0.5, zorder=0)\n    ax_bar.legend(loc=\'lower right\', framealpha=0.2,\n                  facecolor=BG, edgecolor=GRID_COL, labelcolor=TEXT_COL, fontsize=10)\n    ax_bar.set_ylim(-0.5, len(idx) - 0.5)\n\ndef draw_dot(idx):\n    ax_dot.cla()\n    ax_dot.set_facecolor(CARD_BG)\n    \n    if len(idx) == 0:\n        return\n        \n    y = np.arange(len(idx))\n    pp = pos_pct[idx]\n    colors = [POS_COL if p &gt;= 60 else NEU_COL if p &gt;= 40 else NEG_COL for p in pp]\n    sizes = np.clip(total_arr[idx] * 5, 30, 300)\n    \n    ax_dot.scatter(pp, y, c=colors, s=sizes, alpha=0.85,\n                   edgecolors=\'white\', linewidths=0.5)\n    ax_dot.axvline(50, color=MUTED, ls=\'--\', lw=1, alpha=0.6, label=\'Threshold (50%)\')\n    \n    if len(pp) &gt; 0:\n        ax_dot.axvline(pp.mean(), color=ACCENT, ls=\':\', lw=1.5,\n                       alpha=0.8, label=f\'Average: {pp.mean():.0f}%\')\n    \n    wrapped_names = [wrap_name(name, 18) for name in names_arr[idx]]\n    ax_dot.set_yticks(y)\n    ax_dot.set_yticklabels(wrapped_names, fontsize=7.5, color=TEXT_COL)\n    ax_dot.set_xlim(0, 105)\n    ax_dot.set_xlabel(\'Positive Reviews (%)\', color=MUTED, fontsize=10)\n    ax_dot.set_title(\'Positivity Score\', color=TEXT_COL,\n                     fontsize=12, fontweight=\'bold\', pad=10)\n    ax_dot.tick_params(colors=MUTED)\n    ax_dot.grid(axis=\'x\', color=GRID_COL, lw=0.5, alpha=0.5, zorder=0)\n    ax_dot.legend(framealpha=0.2, facecolor=BG, labelcolor=TEXT_COL, fontsize=8, loc=\'lower right\')\n    ax_dot.set_ylim(-0.5, len(idx) - 0.5)\n\ndef draw_pie(idx):\n    ax_pie.cla()\n    ax_pie.set_facecolor(CARD_BG)\n    \n    if len(idx) == 0:\n        return\n        \n    tp = int(pos_arr[idx].sum())\n    tn = int(neu_arr[idx].sum())\n    tng = int(neg_arr[idx].sum())\n    vals = [tp, tn, tng]\n    cols = [POS_COL, NEU_COL, NEG_COL]\n    labels = [\'Positive\', \'Neutral\', \'Negative\']\n    \n    wedges, texts, autotexts = ax_pie.pie(\n        vals, colors=cols, labels=labels, autopct=\'%1.0f%%\', startangle=140,\n        wedgeprops=dict(width=0.6, edgecolor=BG, linewidth=1.5))\n    \n    for t in texts:\n        t.set_color(TEXT_COL)\n        t.set_fontsize(10)\n        t.set_weight(\'bold\')\n    for at in autotexts:\n        at.set_color(\'white\')\n        at.set_fontsize(10)\n        at.set_fontweight(\'bold\')\n    \n    ax_pie.set_title(f\'Sentiment Breakdown\\n({len(idx)} restaurants)\', \n                     color=TEXT_COL, fontsize=11, fontweight=\'bold\', pad=12)\n\ndef draw_heat(idx):\n    ax_heat.cla()\n    ax_heat.set_facecolor(CARD_BG)\n    \n    hi = idx[-8:] if len(idx) &gt;= 8 else idx\n    if len(hi) == 0:\n        return\n        \n    matrix = np.column_stack([pos_pct[hi], neu_pct[hi], neg_pct[hi]])\n    im = ax_heat.imshow(matrix, aspect=\'auto\', cmap=\'RdYlGn\', vmin=0, vmax=100)\n    \n    ax_heat.set_xticks([0, 1, 2])\n    ax_heat.set_xticklabels([\'Positive\', \'Neutral\', \'Negative\'], color=TEXT_COL, fontsize=9, fontweight=\'bold\')\n    ax_heat.set_yticks(range(len(hi)))\n    \n    wrapped_names = [wrap_name(name, 12) for name in names_arr[hi]]\n    ax_heat.set_yticklabels(wrapped_names, fontsize=7.5, color=TEXT_COL)\n    \n    for i in range(len(hi)):\n        for j, v in enumerate(matrix[i]):\n            text_color = \'white\' if v &gt; 50 else \'black\'\n            ax_heat.text(j, i, f\'{v:.0f}\', ha=\'center\', va=\'center\',\n                        fontsize=8, color=text_color, fontweight=\'bold\')\n    \n    ax_heat.set_title(\'Heatmap (Bottom 8)\', color=TEXT_COL, \n                     fontsize=11, fontweight=\'bold\', pad=10)\n    ax_heat.tick_params(colors=MUTED)\n    \n    from mpl_toolkits.axes_grid1 import make_axes_locatable\n    divider = make_axes_locatable(ax_heat)\n    cax = divider.append_axes("right", size="5%", pad=0.05)\n    cbar = plt.colorbar(im, cax=cax)\n    cbar.set_label(\'Percentage (%)\', color=MUTED)\n\ndef draw_info(idx):\n    ax_info.cla()\n    ax_info.set_facecolor(CARD_BG)\n    ax_info.axis(\'off\')\n    \n    if len(idx) == 0:\n        return\n        \n    pp = pos_pct[idx]\n    tt = total_arr[idx]\n    \n    # Find best restaurant - prioritize 100% positive with most reviews\n    perfect_score_indices = np.where(pp == 100)[0]\n    if len(perfect_score_indices) &gt; 0:\n        # Among 100% positive restaurants, pick the one with most reviews\n        best_idx = perfect_score_indices[np.argmax(total_arr[idx[perfect_score_indices]])]\n        best_is_perfect = True\n    else:\n        # If no 100% positive, pick highest positive percentage with most reviews\n        max_pos = np.max(pp)\n        best_candidates = np.where(pp == max_pos)[0]\n        best_idx = best_candidates[np.argmax(total_arr[idx[best_candidates]])]\n        best_is_perfect = False\n    bi = idx[best_idx]\n    \n    # Find worst restaurant - highest negative percentage\n    max_neg = np.max(neg_pct[idx])\n    worst_indices = np.where(neg_pct[idx] == max_neg)[0]\n    if len(worst_indices) &gt; 1:\n        worst_idx = worst_indices[np.argmax(total_arr[idx[worst_indices]])]\n    else:\n        worst_idx = worst_indices[0]\n    wi = idx[worst_idx]\n    \n    # Find most popular - most reviews\n    mi = idx[np.argmax(tt)]\n    \n    ax_info.set_title(\'📊 Key Insights\', color=TEXT_COL,\n                      fontsize=12, fontweight=\'bold\', pad=10)\n    \n    # ===== SECTION 1: OVERVIEW STATS =====\n    y = 0.88\n    \n    # Restaurants\n    ax_info.text(0.08, y, \'Restaurants:\', fontsize=9, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\')\n    ax_info.text(0.92, y, f\'{len(idx)}\', fontsize=10, color=TEXT_COL,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\', fontweight=\'bold\')\n    \n    # Total Reviews\n    y -= 0.09\n    ax_info.text(0.08, y, \'Total Reviews:\', fontsize=9, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\')\n    ax_info.text(0.92, y, f\'{int(tt.sum()):,}\', fontsize=10, color=ACCENT,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\', fontweight=\'bold\')\n    \n    # Average Positivity\n    y -= 0.09\n    avg_pos = pp.mean()\n    ax_info.text(0.08, y, \'Average Positivity:\', fontsize=9, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\')\n    ax_info.text(0.92, y, f\'{avg_pos:.0f}%\', fontsize=10, \n                color=POS_COL if avg_pos &gt; 50 else NEG_COL,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\', fontweight=\'bold\')\n    \n    # Divider\n    y -= 0.07\n    line = plt.Line2D([0.05, 0.95], [y, y],\n                      transform=ax_info.transAxes, color=GRID_COL, linewidth=0.8)\n    ax_info.add_line(line)\n    \n    # ===== SECTION 2: BEST RESTAURANT =====\n    y -= 0.1\n    if best_is_perfect:\n        ax_info.text(0.08, y, \'🏆 Best Restaurant (100% Positive)\', fontsize=9, color=POS_COL,\n                    transform=ax_info.transAxes, va=\'top\', fontweight=\'bold\')\n    else:\n        ax_info.text(0.08, y, \'🏆 Best Restaurant\', fontsize=9, color=POS_COL,\n                    transform=ax_info.transAxes, va=\'top\', fontweight=\'bold\')\n    \n    y -= 0.07\n    best_name = wrap_name(names_arr[bi], 16)\n    ax_info.text(0.92, y, best_name, fontsize=8.5, color=POS_COL,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    y -= 0.06\n    ax_info.text(0.92, y, f\'{pos_pct[bi]:.0f}% positive ({total_arr[bi]} reviews)\', fontsize=8, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    # ===== SECTION 3: NEEDS IMPROVEMENT =====\n    y -= 0.12\n    ax_info.text(0.08, y, \'⚠️ Needs Improvement\', fontsize=9, color=NEG_COL,\n                transform=ax_info.transAxes, va=\'top\', fontweight=\'bold\')\n    \n    y -= 0.07\n    worst_name = wrap_name(names_arr[wi], 16)\n    ax_info.text(0.92, y, worst_name, fontsize=8.5, color=NEG_COL,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    y -= 0.06\n    ax_info.text(0.92, y, f\'{neg_pct[wi]:.0f}% negative ({total_arr[wi]} reviews)\', fontsize=8, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    # ===== SECTION 4: MOST POPULAR =====\n    y -= 0.12\n    ax_info.text(0.08, y, \'⭐ Most Popular\', fontsize=9, color=ACCENT,\n                transform=ax_info.transAxes, va=\'top\', fontweight=\'bold\')\n    \n    y -= 0.07\n    popular_name = wrap_name(names_arr[mi], 16)\n    ax_info.text(0.92, y, popular_name, fontsize=8.5, color=ACCENT,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    y -= 0.06\n    ax_info.text(0.92, y, f\'{total_arr[mi]} reviews ({pos_pct[mi]:.0f}% positive)\', fontsize=8, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    # ===== SECTION 5: SENTIMENT GAUGE =====\n    gauge_y = 0.08\n    rect_bg = plt.Rectangle((0.08, gauge_y), 0.84, 0.025, facecolor=GRID_COL, \n                           transform=ax_info.transAxes)\n    rect_fill = plt.Rectangle((0.08, gauge_y), 0.84 * (avg_pos/100), 0.025, \n                              facecolor=POS_COL, transform=ax_info.transAxes)\n    ax_info.add_patch(rect_bg)\n    ax_info.add_patch(rect_fill)\n    ax_info.text(0.5, gauge_y + 0.04, f\'Overall Score: {avg_pos:.0f}%\', fontsize=9, color=TEXT_COL,\n                fontweight=\'bold\', ha=\'center\', transform=ax_info.transAxes)\n\n# ── STEP 7: Redraw function ───────────────────────────────────\ndef full_redraw():\n    idx = get_sorted_indices()\n    draw_bar(idx)\n    draw_dot(idx)\n    draw_pie(idx)\n    draw_heat(idx)\n    draw_info(idx)\n    fig.canvas.draw_idle()\n\n# ── STEP 8: Callbacks ─────────────────────────────────────────\ndef on_topn(val):\n    state[\'top_n\'] = int(slider_n.val)\n    if state[\'from\'] + state[\'top_n\'] &gt; MAX_N:\n        slider_from.set_val(max(1, MAX_N - state[\'top_n\'] + 1))\n    full_redraw()\n\ndef on_from(val):\n    state[\'from\'] = max(0, int(slider_from.val) - 1)\n    full_redraw()\n\ndef on_top10(event):\n    slider_n.set_val(min(10, MAX_N))\n    slider_from.set_val(1)\n    full_redraw()\n\ndef on_top20(event):\n    slider_n.set_val(min(20, MAX_N))\n    slider_from.set_val(1)\n    full_redraw()\n\ndef on_all(event):\n    slider_n.set_val(MAX_N)\n    slider_from.set_val(1)\n    full_redraw()\n\ndef on_reset(event):\n    slider_n.set_val(min(10, MAX_N))\n    slider_from.set_val(1)\n    state[\'top_n\'] = min(10, MAX_N)\n    state[\'from\'] = 0\n    full_redraw()\n\n# Connect everything\nslider_n.on_changed(on_topn)\nslider_from.on_changed(on_from)\nbtn10.on_clicked(on_top10)\nbtn20.on_clicked(on_top20)\nbtn50.on_clicked(on_all)\nbtn_rst.on_clicked(on_reset)\n\n# Initial draw\nfull_redraw()\nplt.show()\n\nout_data = in_data', 'filename': None}], 'scriptText': 'import matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.widgets import Slider, Button\nimport numpy as np\nimport textwrap\n\n# ── STEP 1: Fetch all restaurants from Orange in_data ─────────\ndata_dict = {}\nfor row in in_data:\n    try:\n        name = str(row[\'restaurant_name\'])\n    except:\n        try:\n            name = str(row.metas[0])\n        except:\n            name = \'Unknown\'\n\n    try:\n        compound = float(row[\'compound\'])\n    except:\n        compound = 0.0\n\n    if name not in data_dict:\n        data_dict[name] = {\'pos\': 0, \'neg\': 0, \'neu\': 0, \'total\': 0}\n    data_dict[name][\'total\'] += 1\n    if compound &gt; 0.05:\n        data_dict[name][\'pos\'] += 1\n    elif compound &lt; -0.05:\n        data_dict[name][\'neg\'] += 1\n    else:\n        data_dict[name][\'neu\'] += 1\n\n# Remove restaurants with less than 5 reviews\ndata_dict = {k: v for k, v in data_dict.items() if v[\'total\'] &gt;= 5}\nALL_NAMES  = list(data_dict.keys())\nMAX_N      = len(ALL_NAMES)\n\n# Build full arrays\nnames_arr  = np.array(ALL_NAMES)\npos_arr    = np.array([data_dict[n][\'pos\']   for n in ALL_NAMES])\nneg_arr    = np.array([data_dict[n][\'neg\']   for n in ALL_NAMES])\nneu_arr    = np.array([data_dict[n][\'neu\']   for n in ALL_NAMES])\ntotal_arr  = np.array([data_dict[n][\'total\'] for n in ALL_NAMES])\npos_pct    = np.where(total_arr &gt; 0, pos_arr / total_arr * 100, 0)\nneg_pct    = np.where(total_arr &gt; 0, neg_arr / total_arr * 100, 0)\nneu_pct    = np.where(total_arr &gt; 0, neu_arr / total_arr * 100, 0)\n\n\n\n# Helper function\ndef wrap_name(name, max_len=18):\n    if len(name) &lt;= max_len:\n        return name\n    return \'\\n\'.join(textwrap.wrap(name, max_len))\n\n# ── STEP 2: Colors ────────────────────────────────────────────\nBG       = \'#0d0f18\'\nCARD_BG  = \'#13162a\'\nACCENT   = \'#7eb8f7\'\nPOS_COL  = \'#2ecc71\'\nNEG_COL  = \'#e74c3c\'\nNEU_COL  = \'#95a5a6\'\nTEXT_COL = \'#e0e4f0\'\nMUTED    = \'#6b7290\'\nGRID_COL = \'#1e2240\'\nWARM_COL = \'#f39c12\'\n\n# ── STEP 3: State ─────────────────────────────────────────────\nstate = {\n    \'top_n\': min(10, MAX_N),\n    \'from\': 0,\n}\n\n# ── STEP 4: Figure with adjusted layout ─────────────────────\nfig = plt.figure(figsize=(22, 13), facecolor=BG)\nfig.canvas.manager.set_window_title(f\'Restaurant Sentiment Dashboard\')\n\n# Main plot area\ngs = gridspec.GridSpec(2, 3,\n    figure=fig, left=0.08, right=0.98,\n    top=0.92, bottom=0.12,\n    hspace=0.4, wspace=0.35)\n\nax_bar  = fig.add_subplot(gs[0, :2])\nax_dot  = fig.add_subplot(gs[0, 2])\nax_pie  = fig.add_subplot(gs[1, 0])\nax_heat = fig.add_subplot(gs[1, 1])\nax_info = fig.add_subplot(gs[1, 2])\n\nfor ax in [ax_bar, ax_dot, ax_pie, ax_heat, ax_info]:\n    ax.set_facecolor(CARD_BG)\n    for sp in ax.spines.values():\n        sp.set_color(GRID_COL)\n\n# Title\nfig.text(0.5, 0.96, \'🍽️ Restaurant Sentiment Dashboard\',\n         ha=\'center\', fontsize=18, fontweight=\'bold\', color=TEXT_COL)\n\n# ── STEP 5: Controls - Clean and simple ──────────────────────\n# Top N Slider\nax_topn = fig.add_axes([0.08, 0.05, 0.25, 0.04], facecolor=CARD_BG)\nax_topn.set_title(\'Number of Restaurants\', color=TEXT_COL, fontsize=10, pad=6)\nslider_n = Slider(ax_topn, \'\', 5, MAX_N,\n                  valinit=state[\'top_n\'], valstep=1,\n                  color=ACCENT, track_color=GRID_COL)\nslider_n.valtext.set_color(ACCENT)\nslider_n.valtext.set_fontsize(10)\n\n# Start from slider\nax_range = fig.add_axes([0.38, 0.05, 0.25, 0.04], facecolor=CARD_BG)\nax_range.set_title(\'Start from Rank\', color=TEXT_COL, fontsize=10, pad=6)\nslider_from = Slider(ax_range, \'\', 1, max(1, MAX_N - 5),\n                     valinit=1, valstep=1,\n                     color=\'#a569bd\', track_color=GRID_COL)\nslider_from.valtext.set_color(\'#a569bd\')\nslider_from.valtext.set_fontsize(10)\n\n# Quick buttons\nax_b10 = fig.add_axes([0.08, 0.01, 0.07, 0.03])\nax_b20 = fig.add_axes([0.16, 0.01, 0.07, 0.03])\nax_b50 = fig.add_axes([0.24, 0.01, 0.07, 0.03])\n\nbtn10 = Button(ax_b10, \'Show 10\', color=\'#1e2433\', hovercolor=\'#2c3e50\')\nbtn20 = Button(ax_b20, \'Show 20\', color=\'#1e2433\', hovercolor=\'#2c3e50\')\nbtn50 = Button(ax_b50, \'Show All\', color=\'#1e2433\', hovercolor=\'#2c3e50\')\nfor b in [btn10, btn20, btn50]:\n    b.label.set_color(ACCENT)\n    b.label.set_fontsize(8)\n\n# Reset button\nax_rst = fig.add_axes([0.33, 0.01, 0.08, 0.03])\nbtn_rst = Button(ax_rst, \'Reset\', color=\'#1e2433\', hovercolor=\'#2c3e50\')\nbtn_rst.label.set_color(WARM_COL)\nbtn_rst.label.set_fontsize(8)\n\n# ── STEP 6: Helper functions ──────────────────────────────────\ndef get_sorted_indices():\n    order = np.argsort(-pos_pct)\n    start = state[\'from\']\n    end = min(start + state[\'top_n\'], MAX_N)\n    return order[start:end]\n\ndef draw_bar(idx):\n    ax_bar.cla()\n    ax_bar.set_facecolor(CARD_BG)\n    \n    if len(idx) == 0:\n        return\n        \n    y = np.arange(len(idx))\n    h = 0.7\n    \n    left_stack = np.zeros(len(idx))\n    \n    ax_bar.barh(y, pos_arr[idx], h, left=left_stack,\n                color=POS_COL, alpha=0.9, zorder=3, label=\'Positive\')\n    left_stack += pos_arr[idx]\n    \n    ax_bar.barh(y, neu_arr[idx], h, left=left_stack,\n                color=NEU_COL, alpha=0.9, zorder=3, label=\'Neutral\')\n    left_stack += neu_arr[idx]\n    \n    ax_bar.barh(y, neg_arr[idx], h, left=left_stack,\n                color=NEG_COL, alpha=0.9, zorder=3, label=\'Negative\')\n    \n    for i in range(len(idx)):\n        if total_arr[idx[i]] &gt; 5:\n            ax_bar.text(total_arr[idx[i]] + 1, i, f\'{pos_pct[idx[i]]:.0f}%\', \n                       va=\'center\', fontsize=8, color=POS_COL, fontweight=\'bold\')\n\n    n_shown = len(idx)\n    start_r = state[\'from\'] + 1\n    \n    wrapped_names = [wrap_name(name, 25) for name in names_arr[idx]]\n    ax_bar.set_yticks(y)\n    ax_bar.set_yticklabels(wrapped_names, fontsize=8, color=TEXT_COL)\n    ax_bar.set_xlabel(\'Number of Reviews\', color=MUTED, fontsize=10)\n    ax_bar.set_title(f\'Sentiment Distribution (Rank {start_r}–{start_r + n_shown - 1})\',\n                    color=TEXT_COL, fontsize=12, fontweight=\'bold\', pad=10, loc=\'right\')\n    ax_bar.tick_params(colors=MUTED)\n    ax_bar.grid(axis=\'x\', color=GRID_COL, lw=0.5, alpha=0.5, zorder=0)\n    ax_bar.legend(loc=\'lower right\', framealpha=0.2,\n                  facecolor=BG, edgecolor=GRID_COL, labelcolor=TEXT_COL, fontsize=10)\n    ax_bar.set_ylim(-0.5, len(idx) - 0.5)\n\ndef draw_dot(idx):\n    ax_dot.cla()\n    ax_dot.set_facecolor(CARD_BG)\n    \n    if len(idx) == 0:\n        return\n        \n    y = np.arange(len(idx))\n    pp = pos_pct[idx]\n    colors = [POS_COL if p &gt;= 60 else NEU_COL if p &gt;= 40 else NEG_COL for p in pp]\n    sizes = np.clip(total_arr[idx] * 5, 30, 300)\n    \n    ax_dot.scatter(pp, y, c=colors, s=sizes, alpha=0.85,\n                   edgecolors=\'white\', linewidths=0.5)\n    ax_dot.axvline(50, color=MUTED, ls=\'--\', lw=1, alpha=0.6, label=\'Threshold (50%)\')\n    \n    if len(pp) &gt; 0:\n        ax_dot.axvline(pp.mean(), color=ACCENT, ls=\':\', lw=1.5,\n                       alpha=0.8, label=f\'Average: {pp.mean():.0f}%\')\n    \n    wrapped_names = [wrap_name(name, 18) for name in names_arr[idx]]\n    ax_dot.set_yticks(y)\n    ax_dot.set_yticklabels(wrapped_names, fontsize=7.5, color=TEXT_COL)\n    ax_dot.set_xlim(0, 105)\n    ax_dot.set_xlabel(\'Positive Reviews (%)\', color=MUTED, fontsize=10)\n    ax_dot.set_title(\'Positivity Score\', color=TEXT_COL,\n                     fontsize=12, fontweight=\'bold\', pad=10)\n    ax_dot.tick_params(colors=MUTED)\n    ax_dot.grid(axis=\'x\', color=GRID_COL, lw=0.5, alpha=0.5, zorder=0)\n    ax_dot.legend(framealpha=0.2, facecolor=BG, labelcolor=TEXT_COL, fontsize=8, loc=\'lower right\')\n    ax_dot.set_ylim(-0.5, len(idx) - 0.5)\n\ndef draw_pie(idx):\n    ax_pie.cla()\n    ax_pie.set_facecolor(CARD_BG)\n    \n    if len(idx) == 0:\n        return\n        \n    tp = int(pos_arr[idx].sum())\n    tn = int(neu_arr[idx].sum())\n    tng = int(neg_arr[idx].sum())\n    vals = [tp, tn, tng]\n    cols = [POS_COL, NEU_COL, NEG_COL]\n    labels = [\'Positive\', \'Neutral\', \'Negative\']\n    \n    wedges, texts, autotexts = ax_pie.pie(\n        vals, colors=cols, labels=labels, autopct=\'%1.0f%%\', startangle=140,\n        wedgeprops=dict(width=0.6, edgecolor=BG, linewidth=1.5))\n    \n    for t in texts:\n        t.set_color(TEXT_COL)\n        t.set_fontsize(10)\n        t.set_weight(\'bold\')\n    for at in autotexts:\n        at.set_color(\'white\')\n        at.set_fontsize(10)\n        at.set_fontweight(\'bold\')\n    \n    ax_pie.set_title(f\'Sentiment Breakdown\\n({len(idx)} restaurants)\', \n                     color=TEXT_COL, fontsize=11, fontweight=\'bold\', pad=12)\n\ndef draw_heat(idx):\n    ax_heat.cla()\n    ax_heat.set_facecolor(CARD_BG)\n    \n    hi = idx[-8:] if len(idx) &gt;= 8 else idx\n    if len(hi) == 0:\n        return\n        \n    matrix = np.column_stack([pos_pct[hi], neu_pct[hi], neg_pct[hi]])\n    im = ax_heat.imshow(matrix, aspect=\'auto\', cmap=\'RdYlGn\', vmin=0, vmax=100)\n    \n    ax_heat.set_xticks([0, 1, 2])\n    ax_heat.set_xticklabels([\'Positive\', \'Neutral\', \'Negative\'], color=TEXT_COL, fontsize=9, fontweight=\'bold\')\n    ax_heat.set_yticks(range(len(hi)))\n    \n    wrapped_names = [wrap_name(name, 12) for name in names_arr[hi]]\n    ax_heat.set_yticklabels(wrapped_names, fontsize=7.5, color=TEXT_COL)\n    \n    for i in range(len(hi)):\n        for j, v in enumerate(matrix[i]):\n            text_color = \'white\' if v &gt; 50 else \'black\'\n            ax_heat.text(j, i, f\'{v:.0f}\', ha=\'center\', va=\'center\',\n                        fontsize=8, color=text_color, fontweight=\'bold\')\n    \n    ax_heat.set_title(\'Heatmap (Bottom 8)\', color=TEXT_COL, \n                     fontsize=11, fontweight=\'bold\', pad=10)\n    ax_heat.tick_params(colors=MUTED)\n    \n    from mpl_toolkits.axes_grid1 import make_axes_locatable\n    divider = make_axes_locatable(ax_heat)\n    cax = divider.append_axes("right", size="5%", pad=0.05)\n    cbar = plt.colorbar(im, cax=cax)\n    cbar.set_label(\'Percentage (%)\', color=MUTED)\n\ndef draw_info(idx):\n    ax_info.cla()\n    ax_info.set_facecolor(CARD_BG)\n    ax_info.axis(\'off\')\n    \n    if len(idx) == 0:\n        return\n        \n    pp = pos_pct[idx]\n    tt = total_arr[idx]\n    \n    # Find best restaurant - prioritize 100% positive with most reviews\n    perfect_score_indices = np.where(pp == 100)[0]\n    if len(perfect_score_indices) &gt; 0:\n        # Among 100% positive restaurants, pick the one with most reviews\n        best_idx = perfect_score_indices[np.argmax(total_arr[idx[perfect_score_indices]])]\n        best_is_perfect = True\n    else:\n        # If no 100% positive, pick highest positive percentage with most reviews\n        max_pos = np.max(pp)\n        best_candidates = np.where(pp == max_pos)[0]\n        best_idx = best_candidates[np.argmax(total_arr[idx[best_candidates]])]\n        best_is_perfect = False\n    bi = idx[best_idx]\n    \n    # Find worst restaurant - highest negative percentage\n    max_neg = np.max(neg_pct[idx])\n    worst_indices = np.where(neg_pct[idx] == max_neg)[0]\n    if len(worst_indices) &gt; 1:\n        worst_idx = worst_indices[np.argmax(total_arr[idx[worst_indices]])]\n    else:\n        worst_idx = worst_indices[0]\n    wi = idx[worst_idx]\n    \n    # Find most popular - most reviews\n    mi = idx[np.argmax(tt)]\n    \n    ax_info.set_title(\'📊 Key Insights\', color=TEXT_COL,\n                      fontsize=12, fontweight=\'bold\', pad=10)\n    \n    # ===== SECTION 1: OVERVIEW STATS =====\n    y = 0.88\n    \n    # Restaurants\n    ax_info.text(0.08, y, \'Restaurants:\', fontsize=9, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\')\n    ax_info.text(0.92, y, f\'{len(idx)}\', fontsize=10, color=TEXT_COL,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\', fontweight=\'bold\')\n    \n    # Total Reviews\n    y -= 0.09\n    ax_info.text(0.08, y, \'Total Reviews:\', fontsize=9, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\')\n    ax_info.text(0.92, y, f\'{int(tt.sum()):,}\', fontsize=10, color=ACCENT,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\', fontweight=\'bold\')\n    \n    # Average Positivity\n    y -= 0.09\n    avg_pos = pp.mean()\n    ax_info.text(0.08, y, \'Average Positivity:\', fontsize=9, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\')\n    ax_info.text(0.92, y, f\'{avg_pos:.0f}%\', fontsize=10, \n                color=POS_COL if avg_pos &gt; 50 else NEG_COL,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\', fontweight=\'bold\')\n    \n    # Divider\n    y -= 0.07\n    line = plt.Line2D([0.05, 0.95], [y, y],\n                      transform=ax_info.transAxes, color=GRID_COL, linewidth=0.8)\n    ax_info.add_line(line)\n    \n    # ===== SECTION 2: BEST RESTAURANT =====\n    y -= 0.1\n    if best_is_perfect:\n        ax_info.text(0.08, y, \'🏆 Best Restaurant (100% Positive)\', fontsize=9, color=POS_COL,\n                    transform=ax_info.transAxes, va=\'top\', fontweight=\'bold\')\n    else:\n        ax_info.text(0.08, y, \'🏆 Best Restaurant\', fontsize=9, color=POS_COL,\n                    transform=ax_info.transAxes, va=\'top\', fontweight=\'bold\')\n    \n    y -= 0.07\n    best_name = wrap_name(names_arr[bi], 16)\n    ax_info.text(0.92, y, best_name, fontsize=8.5, color=POS_COL,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    y -= 0.06\n    ax_info.text(0.92, y, f\'{pos_pct[bi]:.0f}% positive ({total_arr[bi]} reviews)\', fontsize=8, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    # ===== SECTION 3: NEEDS IMPROVEMENT =====\n    y -= 0.12\n    ax_info.text(0.08, y, \'⚠️ Needs Improvement\', fontsize=9, color=NEG_COL,\n                transform=ax_info.transAxes, va=\'top\', fontweight=\'bold\')\n    \n    y -= 0.07\n    worst_name = wrap_name(names_arr[wi], 16)\n    ax_info.text(0.92, y, worst_name, fontsize=8.5, color=NEG_COL,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    y -= 0.06\n    ax_info.text(0.92, y, f\'{neg_pct[wi]:.0f}% negative ({total_arr[wi]} reviews)\', fontsize=8, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    # ===== SECTION 4: MOST POPULAR =====\n    y -= 0.12\n    ax_info.text(0.08, y, \'⭐ Most Popular\', fontsize=9, color=ACCENT,\n                transform=ax_info.transAxes, va=\'top\', fontweight=\'bold\')\n    \n    y -= 0.07\n    popular_name = wrap_name(names_arr[mi], 16)\n    ax_info.text(0.92, y, popular_name, fontsize=8.5, color=ACCENT,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    y -= 0.06\n    ax_info.text(0.92, y, f\'{total_arr[mi]} reviews ({pos_pct[mi]:.0f}% positive)\', fontsize=8, color=MUTED,\n                transform=ax_info.transAxes, va=\'top\', ha=\'right\')\n    \n    # ===== SECTION 5: SENTIMENT GAUGE =====\n    gauge_y = 0.08\n    rect_bg = plt.Rectangle((0.08, gauge_y), 0.84, 0.025, facecolor=GRID_COL, \n                           transform=ax_info.transAxes)\n    rect_fill = plt.Rectangle((0.08, gauge_y), 0.84 * (avg_pos/100), 0.025, \n                              facecolor=POS_COL, transform=ax_info.transAxes)\n    ax_info.add_patch(rect_bg)\n    ax_info.add_patch(rect_fill)\n    ax_info.text(0.5, gauge_y + 0.04, f\'Overall Score: {avg_pos:.0f}%\', fontsize=9, color=TEXT_COL,\n                fontweight=\'bold\', ha=\'center\', transform=ax_info.transAxes)\n\n# ── STEP 7: Redraw function ───────────────────────────────────\ndef full_redraw():\n    idx = get_sorted_indices()\n    draw_bar(idx)\n    draw_dot(idx)\n    draw_pie(idx)\n    draw_heat(idx)\n    draw_info(idx)\n    fig.canvas.draw_idle()\n\n# ── STEP 8: Callbacks ─────────────────────────────────────────\ndef on_topn(val):\n    state[\'top_n\'] = int(slider_n.val)\n    if state[\'from\'] + state[\'top_n\'] &gt; MAX_N:\n        slider_from.set_val(max(1, MAX_N - state[\'top_n\'] + 1))\n    full_redraw()\n\ndef on_from(val):\n    state[\'from\'] = max(0, int(slider_from.val) - 1)\n    full_redraw()\n\ndef on_top10(event):\n    slider_n.set_val(min(10, MAX_N))\n    slider_from.set_val(1)\n    full_redraw()\n\ndef on_top20(event):\n    slider_n.set_val(min(20, MAX_N))\n    slider_from.set_val(1)\n    full_redraw()\n\ndef on_all(event):\n    slider_n.set_val(MAX_N)\n    slider_from.set_val(1)\n    full_redraw()\n\ndef on_reset(event):\n    slider_n.set_val(min(10, MAX_N))\n    slider_from.set_val(1)\n    state[\'top_n\'] = min(10, MAX_N)\n    state[\'from\'] = 0\n    full_redraw()\n\n# Connect everything\nslider_n.on_changed(on_topn)\nslider_from.on_changed(on_from)\nbtn10.on_clicked(on_top10)\nbtn20.on_clicked(on_top20)\nbtn50.on_clicked(on_all)\nbtn_rst.on_clicked(on_reset)\n\n# Initial draw\nfull_redraw()\nplt.show()\n\nout_data = in_data', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa1\x00\x00\x00a\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
		<properties node_id="20" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\x8f\x00\x00\x00d\x00\x00\x04\xb1\x00\x00\x02\xda\x00\x00\x01\x90\x00\x00\x00\x82\x00\x00\x04\xb0\x00\x00\x02\xd9\x00\x00\x00\x00\x00\x00\x00\x00\x05\x00\x00\x00\x01\x90\x00\x00\x00\x82\x00\x00\x04\xb0\x00\x00\x02\xd9', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'import matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.widgets import Slider, Button\nimport numpy as np\nimport textwrap\nimport re\nfrom collections import Counter\nimport pandas as pd\n \n# ── STEP 1: Fetch all restaurants from Orange in_data ─────────\ndata_dict = {}\nnegative_reviews_dict = {}\nall_reviews_dict = {}\nall_negative_texts = []\n \nprint("="*70)\nprint("LOADING RESTAURANT DATA...")\nprint("="*70)\n \n# Find review text column\nsample_row = None\nreview_text_column = None\n \nfor row in in_data:\n    sample_row = row\n    break\n \nif sample_row:\n    print("Available fields:", list(sample_row.keys()) if hasattr(sample_row, \'keys\') else dir(sample_row))\n    \n    if hasattr(sample_row, \'keys\'):\n        for key in sample_row.keys():\n            val = str(sample_row[key])\n            if len(val) &gt; 50 and (\'review\' in key.lower() or \'text\' in key.lower() or \'comment\' in key.lower()):\n                review_text_column = key\n                print(f"\\n✓ Found review text column: \'{key}\'")\n                break\n        \n        if not review_text_column:\n            for key in sample_row.keys():\n                val = str(sample_row[key])\n                if len(val) &gt; 100:\n                    review_text_column = key\n                    print(f"\\n✓ Using column \'{key}\' for review text")\n                    break\n    \n    print("="*70)\n \n# Issue patterns for detection only\nissue_patterns = {\n    \'Cold Food\': [\'cold\', \'warm\', \'temperature\', \'frozen\', \'lukewarm\', \'not hot\', \'cool\', \'chilled\'],\n    \'Slow Service\': [\'slow\', \'wait\', \'delay\', \'late\', \'long time\', \'waited\', \'waiting\', \'took long\'],\n    \'Food Quality\': [\'bad\', \'terrible\', \'awful\', \'disgusting\', \'horrible\', \'mediocre\', \'bland\', \'tasteless\'],\n    \'Overpriced\': [\'expensive\', \'pricey\', \'overpriced\', \'cost\', \'cheap quality\', \'rip off\', \'not worth\'],\n    \'Rude Staff\': [\'rude\', \'unfriendly\', \'arrogant\', \'attitude\', \'disrespectful\', \'mean\', \'unprofessional\'],\n    \'Cleanliness\': [\'dirty\', \'filthy\', \'hygiene\', \'mold\', \'dusty\', \'sticky\', \'messy\', \'unclean\'],\n    \'Small Portions\': [\'small\', \'portion\', \'quantity\', \'little\', \'tiny\', \'half\', \'not enough\', \'skimpy\'],\n    \'Reservation\': [\'reservation\', \'booking\', \'waitlist\', \'table\', \'seating\', \'host\', \'booked\'],\n    \'Delivery\': [\'delivery\', \'late order\', \'missing item\', \'wrong order\', \'takeout\', \'uber\', \'deliveroo\'],\n    \'Temperature\': [\'undercooked\', \'overcooked\', \'burnt\', \'raw\', \'burned\', \'dry\', \'overdone\'],\n    \'Freshness\': [\'fresh\', \'stale\', \'old\', \'expired\', \'spoiled\', \'rotten\', \'off\', \'smelly\'],\n}\n \n# Load data with FULL text preservation\nfor row in in_data:\n    try:\n        name = str(row[\'restaurant_name\'])\n    except:\n        try:\n            name = str(row.metas[0])\n        except:\n            name = \'Unknown\'\n \n    try:\n        compound = float(row[\'compound\'])\n    except:\n        compound = 0.0\n    \n    review_text = ""\n    if review_text_column:\n        try:\n            val = row[review_text_column]\n            if val and len(str(val)) &gt; 5:\n                review_text = str(val)\n        except:\n            pass\n    \n    if not review_text:\n        possible_text_columns = [\'review_text\', \'text\', \'review\', \'comment\', \'Review\', \'Text\', \'content\', \'message\', \'reviews\']\n        for col in possible_text_columns:\n            try:\n                val = row[col]\n                if val and len(str(val)) &gt; 5:\n                    review_text = str(val)\n                    break\n            except:\n                continue\n    \n    if not review_text or len(review_text) &lt; 5:\n        review_text = "[NO TEXT AVAILABLE]"\n \n    if name not in data_dict:\n        data_dict[name] = {\'pos\': 0, \'neg\': 0, \'neu\': 0, \'total\': 0}\n        negative_reviews_dict[name] = []\n        all_reviews_dict[name] = []\n    \n    data_dict[name][\'total\'] += 1\n    all_reviews_dict[name].append({\'text\': review_text, \'compound\': compound})\n    \n    if compound &gt; 0.05:\n        data_dict[name][\'pos\'] += 1\n    elif compound &lt; -0.05:\n        data_dict[name][\'neg\'] += 1\n        negative_reviews_dict[name].append(review_text)\n        if review_text != "[NO TEXT AVAILABLE]":\n            all_negative_texts.append(review_text)\n    else:\n        data_dict[name][\'neu\'] += 1\n \n# Keep ALL restaurants\nALL_NAMES = list(data_dict.keys())\nMAX_N = len(ALL_NAMES)\n \n# Build arrays\nnames_arr = np.array(ALL_NAMES)\npos_arr = np.array([data_dict[n][\'pos\'] for n in ALL_NAMES])\nneg_arr = np.array([data_dict[n][\'neg\'] for n in ALL_NAMES])\nneu_arr = np.array([data_dict[n][\'neu\'] for n in ALL_NAMES])\ntotal_arr = np.array([data_dict[n][\'total\'] for n in ALL_NAMES])\nneg_pct = np.where(total_arr &gt; 0, neg_arr / total_arr * 100, 0)\n \n# Analyze issues per review\nrestaurant_detailed_issues = {}\n \nfor name, reviews in negative_reviews_dict.items():\n    detailed_issues = []\n    for review in reviews:\n        review_issues = []\n        for issue_name, keywords in issue_patterns.items():\n            for keyword in keywords:\n                if keyword in str(review).lower():\n                    review_issues.append(issue_name)\n                    break\n        if review_issues:\n            detailed_issues.append({\n                \'text\': review,\n                \'issues\': list(set(review_issues))\n            })\n        else:\n            detailed_issues.append({\n                \'text\': review,\n                \'issues\': [\'General complaint\']\n            })\n    restaurant_detailed_issues[name] = detailed_issues\n \nprint("="*70)\n \n# ── STEP 3: Colors ────────────────────────────────────────────\nBG = \'#0a0c12\'\nCARD_BG = \'#13162a\'\nACCENT = \'#5dade2\'\nTEXT_COL = \'#e0e4f0\'\nMUTED = \'#6b7290\'\nGRID_COL = \'#1e2433\'\nSELECT_COL = \'#3498db\'\n \n# ── STEP 4: Figure ────────────────────────────────────────────\nfig = plt.figure(figsize=(24, 14), facecolor=BG)\nfig.canvas.manager.set_window_title(\'🍽️ Restaurant Review Analytics\')\n \n# Adjusted left margin to give more space for restaurant names\ngs = gridspec.GridSpec(1, 2, figure=fig, left=0.12, right=0.96, top=0.90, bottom=0.10,\n                       hspace=0.35, wspace=0.35, width_ratios=[1, 1.3])\n \nax_neg_bar = fig.add_subplot(gs[0, 0])\nax_reviews = fig.add_subplot(gs[0, 1])\n \nfor ax in [ax_neg_bar, ax_reviews]:\n    ax.set_facecolor(CARD_BG)\n    for sp in ax.spines.values():\n        sp.set_color(GRID_COL)\n        sp.set_linewidth(1.5)\n \n# Title\nfig.text(0.5, 0.96, \'🍽️ RESTAURANT REVIEW INTELLIGENCE DASHBOARD\',\n         ha=\'center\', fontsize=22, fontweight=\'bold\', color=TEXT_COL)\nfig.text(0.5, 0.93, \'━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\',\n         ha=\'center\', fontsize=12, color=ACCENT, alpha=0.5)\n \n# ── STEP 5: Controls ──────────────────────────────────────────\nax_topn = fig.add_axes([0.08, 0.05, 0.25, 0.04], facecolor=CARD_BG)\nslider_n = Slider(ax_topn, \'\', 5, MAX_N, valinit=min(15, MAX_N), valstep=1,\n                  color=ACCENT, track_color=GRID_COL)\nslider_n.valtext.set_color(ACCENT)\n \nax_rst = fig.add_axes([0.36, 0.04, 0.08, 0.05])\nbtn_rst = Button(ax_rst, \'⟳ RESET\', color=\'#1e2433\', hovercolor=\'#2c3e50\')\nbtn_rst.label.set_color(ACCENT)\n \nax_selected_info = fig.add_axes([0.48, 0.04, 0.32, 0.05], facecolor=\'#1a1d35\')\nax_selected_info.axis(\'off\')\nselected_restaurant_text = ax_selected_info.text(0.05, 0.5, \'⚡ NO RESTAURANT SELECTED\',\n                                                  color=MUTED, fontsize=10, va=\'center\', fontweight=\'bold\')\n \ncurrent_selected_restaurant = None\ncurrent_data = []\n \ndef get_sorted_restaurants(top_n):\n    data = [(names_arr[i], neg_pct[i], total_arr[i], i) for i in range(len(names_arr))]\n    data.sort(key=lambda x: x[1], reverse=True)\n    return data[:top_n]\n \ndef draw_negative_bar(restaurant_data):\n    ax_neg_bar.cla()\n    ax_neg_bar.set_facecolor(CARD_BG)\n    \n    if not restaurant_data:\n        ax_neg_bar.text(0.5, 0.5, \'No data available\', ha=\'center\', va=\'center\', color=MUTED, fontsize=12)\n        return\n    \n    names = [item[0] for item in restaurant_data]\n    neg_scores = [item[1] for item in restaurant_data]\n    review_counts = [item[2] for item in restaurant_data]\n    \n    y = np.arange(len(names))\n    bar_height = 0.65\n    \n    colors = []\n    for score in neg_scores:\n        if score &gt; 30:\n            colors.append(\'#e74c3c\')\n        elif score &gt; 20:\n            colors.append(\'#f39c12\')\n        elif score &gt; 10:\n            colors.append(\'#3498db\')\n        else:\n            colors.append(\'#2ecc71\')\n    \n    if current_selected_restaurant and current_selected_restaurant in names:\n        selected_idx = names.index(current_selected_restaurant)\n        colors[selected_idx] = SELECT_COL\n    \n    bars = ax_neg_bar.barh(y, neg_scores, height=bar_height, color=colors,\n                           alpha=0.9, edgecolor=\'white\', linewidth=1.2, zorder=3)\n    \n    for i, (neg_score, total) in enumerate(zip(neg_scores, review_counts)):\n        ax_neg_bar.text(neg_score + 1.5, i, f\'{neg_score:.0f}%\',\n                       va=\'center\', fontsize=10, color=TEXT_COL, fontweight=\'bold\')\n    \n    # Wrap names with more space and adjust position\n    wrapped_names = [textwrap.fill(name, 25) for name in names]\n    ax_neg_bar.set_yticks(y)\n    ax_neg_bar.set_yticklabels(wrapped_names, fontsize=9, color=TEXT_COL)\n    # Adjust label position to push them right\n    ax_neg_bar.tick_params(axis=\'y\', pad=10)\n    ax_neg_bar.set_xlabel(\'NEGATIVE REVIEWS (%)\', color=MUTED, fontsize=11, fontweight=\'bold\')\n    ax_neg_bar.tick_params(colors=MUTED)\n    ax_neg_bar.set_xlim(0, max(neg_scores) + 8 if neg_scores else 100)\n    ax_neg_bar.grid(axis=\'x\', color=GRID_COL, lw=0.5, alpha=0.5, zorder=0)\n    ax_neg_bar.set_ylim(-0.5, len(names) - 0.5)\n \ndef draw_reviews_panel():\n    ax_reviews.cla()\n    ax_reviews.set_facecolor(CARD_BG)\n    ax_reviews.axis(\'off\')\n    \n    if not current_selected_restaurant:\n        ax_reviews.text(0.5, 0.5, \'👆 CLICK ON ANY BAR ABOVE\\n\\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n\\nSELECT A RESTAURANT TO SEE\\nITS NEGATIVE REVIEWS\',\n                       ha=\'center\', va=\'center\', color=MUTED, fontsize=13,\n                       transform=ax_reviews.transAxes, fontweight=\'bold\')\n        return\n    \n    detailed = restaurant_detailed_issues.get(current_selected_restaurant, [])\n    neg_count = neg_arr[ALL_NAMES.index(current_selected_restaurant)]\n    \n    # Removed "NEGATIVE REVIEWS ANALYSIS" title\n    ax_reviews.text(0.5, 0.96, f\'{current_selected_restaurant}\', color=\'#f39c12\',\n                    fontsize=13, fontweight=\'bold\', ha=\'center\', transform=ax_reviews.transAxes, style=\'italic\')\n    \n    # Removed the stats box with total negative reviews\n    if not detailed:\n        ax_reviews.text(0.5, 0.5, \'No review text available\', ha=\'center\', va=\'center\',\n                       color=MUTED, fontsize=12, transform=ax_reviews.transAxes)\n        return\n    \n    # Show ALL reviews with FULL TEXT\n    y_pos = 0.88\n    for idx, review_data in enumerate(detailed):\n        if y_pos &lt; 0.06:\n            break\n        \n        review_text = review_data[\'text\']\n        issues = \', \'.join(review_data[\'issues\'])\n        \n        # Card border top\n        ax_reviews.text(0.02, y_pos, f\'┌─────────────────────────────────────────────────────────────────────────────────────┐\',\n                       fontsize=7, color=GRID_COL, transform=ax_reviews.transAxes, va=\'top\')\n        y_pos -= 0.022\n        \n        # Header\n        ax_reviews.text(0.05, y_pos, f\'📌 REVIEW #{idx+1}  |  ISSUES FOUND: {issues}\',\n                       fontsize=9, color=\'#f39c12\', transform=ax_reviews.transAxes, va=\'top\', fontweight=\'bold\')\n        y_pos -= 0.04\n        \n        # FULL REVIEW TEXT\n        wrapped_text = textwrap.fill(f\'💬 "{review_text}"\', width=90)\n        ax_reviews.text(0.05, y_pos, wrapped_text, fontsize=8, color=TEXT_COL,\n                       transform=ax_reviews.transAxes, va=\'top\')\n        y_pos -= (wrapped_text.count(\'\\n\') + 1) * 0.032 + 0.045\n        \n        # Card border bottom\n        ax_reviews.text(0.02, y_pos, f\'└─────────────────────────────────────────────────────────────────────────────────────┘\',\n                       fontsize=7, color=GRID_COL, transform=ax_reviews.transAxes, va=\'top\')\n        y_pos -= 0.028\n        \n        # Separator between reviews\n        if idx &lt; len(detailed) - 1:\n            ax_reviews.text(0.5, y_pos, \'▼\', fontsize=8, color=GRID_COL, ha=\'center\',\n                           transform=ax_reviews.transAxes, va=\'top\')\n            y_pos -= 0.035\n \ndef update_dashboard(val=None, keep_selection=False):\n    global current_data\n    \n    top_n = int(slider_n.val)\n    \n    if not keep_selection:\n        global current_selected_restaurant\n        current_selected_restaurant = None\n        selected_restaurant_text.set_text(\'⚡ NO RESTAURANT SELECTED\')\n        selected_restaurant_text.set_color(MUTED)\n    \n    current_data = get_sorted_restaurants(top_n)\n    \n    draw_negative_bar(current_data)\n    draw_reviews_panel()\n    \n    fig.canvas.draw_idle()\n \ndef reset_dashboard(event):\n    slider_n.set_val(min(15, MAX_N))\n    global current_selected_restaurant\n    current_selected_restaurant = None\n    selected_restaurant_text.set_text(\'⚡ NO RESTAURANT SELECTED\')\n    selected_restaurant_text.set_color(MUTED)\n    update_dashboard()\n \ndef on_bar_click(event):\n    global current_selected_restaurant\n    \n    if event.inaxes == ax_neg_bar:\n        for i, bar in enumerate(ax_neg_bar.patches):\n            if event.ydata &gt; bar.get_y() and event.ydata &lt; bar.get_y() + bar.get_height():\n                if i &lt; len(current_data):\n                    current_selected_restaurant = current_data[i][0]\n                    selected_restaurant_text.set_text(f\'✅ SELECTED: {current_selected_restaurant[:35]}\')\n                    selected_restaurant_text.set_color(ACCENT)\n                    update_dashboard(keep_selection=True)\n                    break\n \nslider_n.on_changed(update_dashboard)\nbtn_rst.on_clicked(reset_dashboard)\nfig.canvas.mpl_connect(\'button_press_event\', on_bar_click)\n \nupdate_dashboard()\nplt.show()\n \nout_data = pd.DataFrame([{\n    \'Restaurant\': name,\n    \'Negative_Percentage\': f\'{neg_pct[i]:.1f}\',\n    \'Total_Reviews\': total_arr[i],\n    \'Negative_Count\': neg_arr[i]\n} for i, name in enumerate(ALL_NAMES)])\n \nprint("\\n" + "="*70)\nprint("✅ DASHBOARD READY")\nprint("="*70)\nprint("="*70)', 'filename': None}], 'scriptText': 'import matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.widgets import Slider, Button\nimport numpy as np\nimport textwrap\nimport re\nfrom collections import Counter\nimport pandas as pd\n \n# ── STEP 1: Fetch all restaurants from Orange in_data ─────────\ndata_dict = {}\nnegative_reviews_dict = {}\nall_reviews_dict = {}\nall_negative_texts = []\n \nprint("="*70)\nprint("LOADING RESTAURANT DATA...")\nprint("="*70)\n \n# Find review text column\nsample_row = None\nreview_text_column = None\n \nfor row in in_data:\n    sample_row = row\n    break\n \nif sample_row:\n    print("Available fields:", list(sample_row.keys()) if hasattr(sample_row, \'keys\') else dir(sample_row))\n    \n    if hasattr(sample_row, \'keys\'):\n        for key in sample_row.keys():\n            val = str(sample_row[key])\n            if len(val) &gt; 50 and (\'review\' in key.lower() or \'text\' in key.lower() or \'comment\' in key.lower()):\n                review_text_column = key\n                print(f"\\n✓ Found review text column: \'{key}\'")\n                break\n        \n        if not review_text_column:\n            for key in sample_row.keys():\n                val = str(sample_row[key])\n                if len(val) &gt; 100:\n                    review_text_column = key\n                    print(f"\\n✓ Using column \'{key}\' for review text")\n                    break\n    \n    print("="*70)\n \n# Issue patterns for detection only\nissue_patterns = {\n    \'Cold Food\': [\'cold\', \'warm\', \'temperature\', \'frozen\', \'lukewarm\', \'not hot\', \'cool\', \'chilled\'],\n    \'Slow Service\': [\'slow\', \'wait\', \'delay\', \'late\', \'long time\', \'waited\', \'waiting\', \'took long\'],\n    \'Food Quality\': [\'bad\', \'terrible\', \'awful\', \'disgusting\', \'horrible\', \'mediocre\', \'bland\', \'tasteless\'],\n    \'Overpriced\': [\'expensive\', \'pricey\', \'overpriced\', \'cost\', \'cheap quality\', \'rip off\', \'not worth\'],\n    \'Rude Staff\': [\'rude\', \'unfriendly\', \'arrogant\', \'attitude\', \'disrespectful\', \'mean\', \'unprofessional\'],\n    \'Cleanliness\': [\'dirty\', \'filthy\', \'hygiene\', \'mold\', \'dusty\', \'sticky\', \'messy\', \'unclean\'],\n    \'Small Portions\': [\'small\', \'portion\', \'quantity\', \'little\', \'tiny\', \'half\', \'not enough\', \'skimpy\'],\n    \'Reservation\': [\'reservation\', \'booking\', \'waitlist\', \'table\', \'seating\', \'host\', \'booked\'],\n    \'Delivery\': [\'delivery\', \'late order\', \'missing item\', \'wrong order\', \'takeout\', \'uber\', \'deliveroo\'],\n    \'Temperature\': [\'undercooked\', \'overcooked\', \'burnt\', \'raw\', \'burned\', \'dry\', \'overdone\'],\n    \'Freshness\': [\'fresh\', \'stale\', \'old\', \'expired\', \'spoiled\', \'rotten\', \'off\', \'smelly\'],\n}\n \n# Load data with FULL text preservation\nfor row in in_data:\n    try:\n        name = str(row[\'restaurant_name\'])\n    except:\n        try:\n            name = str(row.metas[0])\n        except:\n            name = \'Unknown\'\n \n    try:\n        compound = float(row[\'compound\'])\n    except:\n        compound = 0.0\n    \n    review_text = ""\n    if review_text_column:\n        try:\n            val = row[review_text_column]\n            if val and len(str(val)) &gt; 5:\n                review_text = str(val)\n        except:\n            pass\n    \n    if not review_text:\n        possible_text_columns = [\'review_text\', \'text\', \'review\', \'comment\', \'Review\', \'Text\', \'content\', \'message\', \'reviews\']\n        for col in possible_text_columns:\n            try:\n                val = row[col]\n                if val and len(str(val)) &gt; 5:\n                    review_text = str(val)\n                    break\n            except:\n                continue\n    \n    if not review_text or len(review_text) &lt; 5:\n        review_text = "[NO TEXT AVAILABLE]"\n \n    if name not in data_dict:\n        data_dict[name] = {\'pos\': 0, \'neg\': 0, \'neu\': 0, \'total\': 0}\n        negative_reviews_dict[name] = []\n        all_reviews_dict[name] = []\n    \n    data_dict[name][\'total\'] += 1\n    all_reviews_dict[name].append({\'text\': review_text, \'compound\': compound})\n    \n    if compound &gt; 0.05:\n        data_dict[name][\'pos\'] += 1\n    elif compound &lt; -0.05:\n        data_dict[name][\'neg\'] += 1\n        negative_reviews_dict[name].append(review_text)\n        if review_text != "[NO TEXT AVAILABLE]":\n            all_negative_texts.append(review_text)\n    else:\n        data_dict[name][\'neu\'] += 1\n \n# Keep ALL restaurants\nALL_NAMES = list(data_dict.keys())\nMAX_N = len(ALL_NAMES)\n \n# Build arrays\nnames_arr = np.array(ALL_NAMES)\npos_arr = np.array([data_dict[n][\'pos\'] for n in ALL_NAMES])\nneg_arr = np.array([data_dict[n][\'neg\'] for n in ALL_NAMES])\nneu_arr = np.array([data_dict[n][\'neu\'] for n in ALL_NAMES])\ntotal_arr = np.array([data_dict[n][\'total\'] for n in ALL_NAMES])\nneg_pct = np.where(total_arr &gt; 0, neg_arr / total_arr * 100, 0)\n \n# Analyze issues per review\nrestaurant_detailed_issues = {}\n \nfor name, reviews in negative_reviews_dict.items():\n    detailed_issues = []\n    for review in reviews:\n        review_issues = []\n        for issue_name, keywords in issue_patterns.items():\n            for keyword in keywords:\n                if keyword in str(review).lower():\n                    review_issues.append(issue_name)\n                    break\n        if review_issues:\n            detailed_issues.append({\n                \'text\': review,\n                \'issues\': list(set(review_issues))\n            })\n        else:\n            detailed_issues.append({\n                \'text\': review,\n                \'issues\': [\'General complaint\']\n            })\n    restaurant_detailed_issues[name] = detailed_issues\n \nprint("="*70)\n \n# ── STEP 3: Colors ────────────────────────────────────────────\nBG = \'#0a0c12\'\nCARD_BG = \'#13162a\'\nACCENT = \'#5dade2\'\nTEXT_COL = \'#e0e4f0\'\nMUTED = \'#6b7290\'\nGRID_COL = \'#1e2433\'\nSELECT_COL = \'#3498db\'\n \n# ── STEP 4: Figure ────────────────────────────────────────────\nfig = plt.figure(figsize=(24, 14), facecolor=BG)\nfig.canvas.manager.set_window_title(\'🍽️ Restaurant Review Analytics\')\n \n# Adjusted left margin to give more space for restaurant names\ngs = gridspec.GridSpec(1, 2, figure=fig, left=0.12, right=0.96, top=0.90, bottom=0.10,\n                       hspace=0.35, wspace=0.35, width_ratios=[1, 1.3])\n \nax_neg_bar = fig.add_subplot(gs[0, 0])\nax_reviews = fig.add_subplot(gs[0, 1])\n \nfor ax in [ax_neg_bar, ax_reviews]:\n    ax.set_facecolor(CARD_BG)\n    for sp in ax.spines.values():\n        sp.set_color(GRID_COL)\n        sp.set_linewidth(1.5)\n \n# Title\nfig.text(0.5, 0.96, \'🍽️ RESTAURANT REVIEW INTELLIGENCE DASHBOARD\',\n         ha=\'center\', fontsize=22, fontweight=\'bold\', color=TEXT_COL)\nfig.text(0.5, 0.93, \'━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\',\n         ha=\'center\', fontsize=12, color=ACCENT, alpha=0.5)\n \n# ── STEP 5: Controls ──────────────────────────────────────────\nax_topn = fig.add_axes([0.08, 0.05, 0.25, 0.04], facecolor=CARD_BG)\nslider_n = Slider(ax_topn, \'\', 5, MAX_N, valinit=min(15, MAX_N), valstep=1,\n                  color=ACCENT, track_color=GRID_COL)\nslider_n.valtext.set_color(ACCENT)\n \nax_rst = fig.add_axes([0.36, 0.04, 0.08, 0.05])\nbtn_rst = Button(ax_rst, \'⟳ RESET\', color=\'#1e2433\', hovercolor=\'#2c3e50\')\nbtn_rst.label.set_color(ACCENT)\n \nax_selected_info = fig.add_axes([0.48, 0.04, 0.32, 0.05], facecolor=\'#1a1d35\')\nax_selected_info.axis(\'off\')\nselected_restaurant_text = ax_selected_info.text(0.05, 0.5, \'⚡ NO RESTAURANT SELECTED\',\n                                                  color=MUTED, fontsize=10, va=\'center\', fontweight=\'bold\')\n \ncurrent_selected_restaurant = None\ncurrent_data = []\n \ndef get_sorted_restaurants(top_n):\n    data = [(names_arr[i], neg_pct[i], total_arr[i], i) for i in range(len(names_arr))]\n    data.sort(key=lambda x: x[1], reverse=True)\n    return data[:top_n]\n \ndef draw_negative_bar(restaurant_data):\n    ax_neg_bar.cla()\n    ax_neg_bar.set_facecolor(CARD_BG)\n    \n    if not restaurant_data:\n        ax_neg_bar.text(0.5, 0.5, \'No data available\', ha=\'center\', va=\'center\', color=MUTED, fontsize=12)\n        return\n    \n    names = [item[0] for item in restaurant_data]\n    neg_scores = [item[1] for item in restaurant_data]\n    review_counts = [item[2] for item in restaurant_data]\n    \n    y = np.arange(len(names))\n    bar_height = 0.65\n    \n    colors = []\n    for score in neg_scores:\n        if score &gt; 30:\n            colors.append(\'#e74c3c\')\n        elif score &gt; 20:\n            colors.append(\'#f39c12\')\n        elif score &gt; 10:\n            colors.append(\'#3498db\')\n        else:\n            colors.append(\'#2ecc71\')\n    \n    if current_selected_restaurant and current_selected_restaurant in names:\n        selected_idx = names.index(current_selected_restaurant)\n        colors[selected_idx] = SELECT_COL\n    \n    bars = ax_neg_bar.barh(y, neg_scores, height=bar_height, color=colors,\n                           alpha=0.9, edgecolor=\'white\', linewidth=1.2, zorder=3)\n    \n    for i, (neg_score, total) in enumerate(zip(neg_scores, review_counts)):\n        ax_neg_bar.text(neg_score + 1.5, i, f\'{neg_score:.0f}%\',\n                       va=\'center\', fontsize=10, color=TEXT_COL, fontweight=\'bold\')\n    \n    # Wrap names with more space and adjust position\n    wrapped_names = [textwrap.fill(name, 25) for name in names]\n    ax_neg_bar.set_yticks(y)\n    ax_neg_bar.set_yticklabels(wrapped_names, fontsize=9, color=TEXT_COL)\n    # Adjust label position to push them right\n    ax_neg_bar.tick_params(axis=\'y\', pad=10)\n    ax_neg_bar.set_xlabel(\'NEGATIVE REVIEWS (%)\', color=MUTED, fontsize=11, fontweight=\'bold\')\n    ax_neg_bar.tick_params(colors=MUTED)\n    ax_neg_bar.set_xlim(0, max(neg_scores) + 8 if neg_scores else 100)\n    ax_neg_bar.grid(axis=\'x\', color=GRID_COL, lw=0.5, alpha=0.5, zorder=0)\n    ax_neg_bar.set_ylim(-0.5, len(names) - 0.5)\n \ndef draw_reviews_panel():\n    ax_reviews.cla()\n    ax_reviews.set_facecolor(CARD_BG)\n    ax_reviews.axis(\'off\')\n    \n    if not current_selected_restaurant:\n        ax_reviews.text(0.5, 0.5, \'👆 CLICK ON ANY BAR ABOVE\\n\\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n\\nSELECT A RESTAURANT TO SEE\\nITS NEGATIVE REVIEWS\',\n                       ha=\'center\', va=\'center\', color=MUTED, fontsize=13,\n                       transform=ax_reviews.transAxes, fontweight=\'bold\')\n        return\n    \n    detailed = restaurant_detailed_issues.get(current_selected_restaurant, [])\n    neg_count = neg_arr[ALL_NAMES.index(current_selected_restaurant)]\n    \n    # Removed "NEGATIVE REVIEWS ANALYSIS" title\n    ax_reviews.text(0.5, 0.96, f\'{current_selected_restaurant}\', color=\'#f39c12\',\n                    fontsize=13, fontweight=\'bold\', ha=\'center\', transform=ax_reviews.transAxes, style=\'italic\')\n    \n    # Removed the stats box with total negative reviews\n    if not detailed:\n        ax_reviews.text(0.5, 0.5, \'No review text available\', ha=\'center\', va=\'center\',\n                       color=MUTED, fontsize=12, transform=ax_reviews.transAxes)\n        return\n    \n    # Show ALL reviews with FULL TEXT\n    y_pos = 0.88\n    for idx, review_data in enumerate(detailed):\n        if y_pos &lt; 0.06:\n            break\n        \n        review_text = review_data[\'text\']\n        issues = \', \'.join(review_data[\'issues\'])\n        \n        # Card border top\n        ax_reviews.text(0.02, y_pos, f\'┌─────────────────────────────────────────────────────────────────────────────────────┐\',\n                       fontsize=7, color=GRID_COL, transform=ax_reviews.transAxes, va=\'top\')\n        y_pos -= 0.022\n        \n        # Header\n        ax_reviews.text(0.05, y_pos, f\'📌 REVIEW #{idx+1}  |  ISSUES FOUND: {issues}\',\n                       fontsize=9, color=\'#f39c12\', transform=ax_reviews.transAxes, va=\'top\', fontweight=\'bold\')\n        y_pos -= 0.04\n        \n        # FULL REVIEW TEXT\n        wrapped_text = textwrap.fill(f\'💬 "{review_text}"\', width=90)\n        ax_reviews.text(0.05, y_pos, wrapped_text, fontsize=8, color=TEXT_COL,\n                       transform=ax_reviews.transAxes, va=\'top\')\n        y_pos -= (wrapped_text.count(\'\\n\') + 1) * 0.032 + 0.045\n        \n        # Card border bottom\n        ax_reviews.text(0.02, y_pos, f\'└─────────────────────────────────────────────────────────────────────────────────────┘\',\n                       fontsize=7, color=GRID_COL, transform=ax_reviews.transAxes, va=\'top\')\n        y_pos -= 0.028\n        \n        # Separator between reviews\n        if idx &lt; len(detailed) - 1:\n            ax_reviews.text(0.5, y_pos, \'▼\', fontsize=8, color=GRID_COL, ha=\'center\',\n                           transform=ax_reviews.transAxes, va=\'top\')\n            y_pos -= 0.035\n \ndef update_dashboard(val=None, keep_selection=False):\n    global current_data\n    \n    top_n = int(slider_n.val)\n    \n    if not keep_selection:\n        global current_selected_restaurant\n        current_selected_restaurant = None\n        selected_restaurant_text.set_text(\'⚡ NO RESTAURANT SELECTED\')\n        selected_restaurant_text.set_color(MUTED)\n    \n    current_data = get_sorted_restaurants(top_n)\n    \n    draw_negative_bar(current_data)\n    draw_reviews_panel()\n    \n    fig.canvas.draw_idle()\n \ndef reset_dashboard(event):\n    slider_n.set_val(min(15, MAX_N))\n    global current_selected_restaurant\n    current_selected_restaurant = None\n    selected_restaurant_text.set_text(\'⚡ NO RESTAURANT SELECTED\')\n    selected_restaurant_text.set_color(MUTED)\n    update_dashboard()\n \ndef on_bar_click(event):\n    global current_selected_restaurant\n    \n    if event.inaxes == ax_neg_bar:\n        for i, bar in enumerate(ax_neg_bar.patches):\n            if event.ydata &gt; bar.get_y() and event.ydata &lt; bar.get_y() + bar.get_height():\n                if i &lt; len(current_data):\n                    current_selected_restaurant = current_data[i][0]\n                    selected_restaurant_text.set_text(f\'✅ SELECTED: {current_selected_restaurant[:35]}\')\n                    selected_restaurant_text.set_color(ACCENT)\n                    update_dashboard(keep_selection=True)\n                    break\n \nslider_n.on_changed(update_dashboard)\nbtn_rst.on_clicked(reset_dashboard)\nfig.canvas.mpl_connect(\'button_press_event\', on_bar_click)\n \nupdate_dashboard()\nplt.show()\n \nout_data = pd.DataFrame([{\n    \'Restaurant\': name,\n    \'Negative_Percentage\': f\'{neg_pct[i]:.1f}\',\n    \'Total_Reviews\': total_arr[i],\n    \'Negative_Count\': neg_arr[i]\n} for i, name in enumerate(ALL_NAMES)])\n \nprint("\\n" + "="*70)\nprint("✅ DASHBOARD READY")\nprint("="*70)\nprint("="*70)', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa1\x00\x00\x00a\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
